{
  "name": "omnimap",
  "version": "0.1.0",
  "description": "Architecture visualization toolkit — supports Mermaid, D3, PlantUML, and more",
  "type": "module",
  "bin": {
    "omm": "dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/",
    "skills/",
    ".claude-plugin/",
    "LICENSE"
  ],
  "homepage": "https://github.com/rsrini7/omnimap",
  "bugs": {
    "url": "https://github.com/rsrini7/omnimap/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rsrini7/omnimap.git"
  },
  "keywords": [
    "architecture",
    "diagram",
    "mermaid",
    "d3",
    "visualization",
    "omnimap",
    "claude-code"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc --noEmit && tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "check-version-sync": "node scripts/check-version-sync.js",
    "sync-version": "node scripts/sync-version.js",
    "prepublishOnly": "npm run build && npm run sync-version"
  },
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "yaml": "^2.8.3"
  },
  "optionalDependencies": {
    "tree-sitter": "0.21.1",
    "tree-sitter-javascript": "0.23.1",
    "tree-sitter-typescript": "0.23.2",
    "tree-sitter-java": "0.23.5",
    "tree-sitter-kotlin": "0.3.8",
    "tree-sitter-scala": "0.24.0",
    "tree-sitter-python": "0.23.4",
    "tree-sitter-go": "0.23.4",
    "tree-sitter-rust": "0.23.1",
    "better-sqlite3": "^11.0.0"
  }
}
